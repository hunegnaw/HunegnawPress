# =================================================================
# HunegnawPress — Environment Template
# =================================================================
# For local development: copy to .env
# For production: copy to ~/Clients/<site>/.env.production
#   and fill in the Deploy Script Variables section

# Database (MariaDB/MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/hunegnawpress"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption key for 2FA secrets
ENCRYPTION_KEY="generate-with: openssl rand -hex 32"

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="52428800"

# Optional: Email (Elastic Email)
# ELASTIC_EMAIL_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"
# EMAIL_FROM_NAME="Your Site"

# Optional: Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# =================================================================
# Deploy Script Variables (only needed in .env.production)
# =================================================================
# SERVER_USER="master_xxxxxxxx"
# SERVER_HOST="xxx.xxx.xxx.xxx"
# SERVER_PATH="/home/xxxxx.cloudwaysapps.com/xxxxx/public_html"
# SSH_KEY="~/.ssh/id_rsa"
# DB_USER="xxxxx"
# DB_PASS="xxxxx"
# DB_NAME="xxxxx"
# DB_HOST="localhost"
# APP_NAME="mysite"
# APP_PORT="4002"
# HEALTH_CHECK_HOST="mysite.com"
